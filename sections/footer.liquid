<footer class="site-footer custom-footer" role="contentinfo">
  <div class="cf-container">
    <div class="cf-grid">
      
      <!-- Newsletter block -->
      <div class="cf-newsletter">
        <h4 class="cf-newsletter__title">SIGN UP TO STAY TUNED!</h4>
        <p class="cf-newsletter__desc">Name to treat your skin. Mind & Body with our products and skincare formulas.</p>
        
        <form action="#" method="post" class="cf-form">
          <div class="cf-form-group">
            <input type="email" placeholder="Email address" required>
            <button type="submit" aria-label="Subscribe">→</button>
          </div>
        </form>
      </div>

      <!-- Links Column 1: Shop -->
      <div class="cf-menu">
        <h4 class="cf-menu-title">Shop Sereko</h4>
        <div class="cf-menu-list">
          <a href="{{ routes.all_products_collection_url }}">All Products</a>
          <a href="{{ routes.collections_url }}/for-acne">For Acne</a>
          <a href="{{ routes.collections_url }}/skin-clarifying">For Skin Clarifying</a>
          <a href="{{ routes.collections_url }}/anti-aging">For Anti-Aging</a>
          <a href="{{ routes.collections_url }}/hyperpigmentation">For Hyperpigmentation</a>
          <a href="{{ routes.collections_url }}/mental-health">For Mental Health</a>
          <a href="{{ routes.collections_url }}/skincare-by-concern">Skincare By Concern</a>
          <a href="{{ routes.all_products_collection_url }}">Shop All</a>
        </div>
      </div>

      <!-- Links Column 2: Help -->
      <div class="cf-menu">
        <h4 class="cf-menu-title">Help</h4>
        <div class="cf-menu-list">
          <a href="/pages/returns">Order & Returns Portal</a>
          <a href="/pages/track-order">Track Your Order</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/privacy-policy">Privacy Policy</a>
          <a href="/pages/terms">Terms & Conditions</a>
          <a href="/pages/shipping">Shipping Policy</a>
          <a href="/pages/contact">Contact Us</a>
        </div>
      </div>

      <!-- Links Column 3: Contact/Connect + Signature image -->
      <div class="cf-menu">
        <h4 class="cf-menu-title">Connect With Us</h4>
        <div class="cf-menu-list">
          <a href="mailto:customercare@serekoshop.com">Email: customercare@serekoshop.com</a>
          <a href="tel:+9194002636XX">Phone: +91 94002636XX</a>
        </div>

        <div class="cf-socials">
          <a href="https://instagram.com" class="cf-social-link" target="_blank" rel="noopener">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163... (use simple IG path or icon)"/></svg>
            IG
          </a>
          <a href="https://facebook.com" class="cf-social-link" target="_blank" rel="noopener">FB</a>
          <a href="https://linkedin.com" class="cf-social-link" target="_blank" rel="noopener">IN</a>
        </div>

        <div class="cf-signature">
          <img src="{{ 'happy-mind-happy-skin.png' | asset_url }}" alt="Happy Mind Happy Skin" width="200" height="80" onerror="this.src='https://via.placeholder.com/200x80/b8bacf/000000?text=Happy+Mind+Happy+Skin'; this.style.opacity='0.5';">
        </div>
      </div>

    </div>
  </div>
</footer>

