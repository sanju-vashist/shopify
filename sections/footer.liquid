<footer class="site-footer" role="contentinfo">
  <div class="footer__marquee">
    <div class="footer__marquee-track">
      {%- assign items = "Dermatologist Tested,Paraben-Free,Cruelty-Free,Made in India,Recyclable Glass,Women-Led Brand" | split: "," -%}
      {%- for i in (1..3) -%}
        {%- for item in items -%}
          <span class="footer__marquee-item">◆ {{ item }}</span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand Col -->
        <div class="footer__brand">
          <a href="{{ routes.root_url }}" class="footer__logo">{{ shop.name | upcase }}</a>
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
          <div class="footer__social">
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Shop Links -->
        <div class="footer__col">
          <h4 class="footer__col-title">Shop</h4>
          <ul class="footer__links">
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections/skincare">Skincare</a></li>
            <li><a href="/collections/haircare">Haircare</a></li>
            <li><a href="/collections/body">Body Care</a></li>
            <li><a href="/collections/new">New Arrivals</a></li>
          </ul>
        </div>

        <!-- Help Links -->
        <div class="footer__col">
          <h4 class="footer__col-title">Help</h4>
          <ul class="footer__links">
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/shipping">Shipping & Returns</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
            <li><a href="{{ routes.account_url }}">My Account</a></li>
            <li><a href="/pages/track-order">Track Order</a></li>
          </ul>
        </div>

        <!-- About Links -->
        <div class="footer__col">
          <h4 class="footer__col-title">Brand</h4>
          <ul class="footer__links">
            <li><a href="/pages/about">About Omnilyx</a></li>
            <li><a href="/pages/ingredients">Our Ingredients</a></li>
            <li><a href="/blogs/news">Journal</a></li>
            <li><a href="/pages/sustainability">Sustainability</a></li>
            <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">
        <p class="footer__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
        <div class="footer__payments">
          <span>We accept:</span>
          <img src="{{ 'payment-icons.png' | asset_url }}" alt="Payment methods" width="200" height="24" onerror="this.style.display='none'">
          <span class="footer__payment-text">Visa · Mastercard · UPI · RazorPay · PayTM</span>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Brand tagline", "default": "Beauty. Wellness. Confidence." },
    { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "text", "id": "social_facebook", "label": "Facebook URL" }
  ]
}
{% endschema %}
