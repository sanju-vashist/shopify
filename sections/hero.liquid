{% style %}
.f3-wrapper {
  background: #2a2a2a; /* Dark background behind the white card */
  padding: 2rem;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Inter', system-ui, sans-serif;
}

.f3-card {
  background: #ffffff;
  border-radius: 40px;
  width: 100%;
  max-width: 1440px;
  min-height: calc(100vh - 4rem);
  padding: 2.5rem 3.5rem 1.5rem 3.5rem;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.f3-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  position: relative;
  z-index: 10;
}

.f3-brand-group {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.f3-brand-line {
  width: 80px;
  height: 4px;
  background: #000;
}

.f3-brand-text {
  font-size: 1.6rem;
  letter-spacing: 0.02em;
}

.f3-brand-text span:first-child {
  font-weight: 900;
  font-style: italic;
  font-family: 'Monument Extended', 'Arial Black', sans-serif; /* fallback for wide bold font */
}

.f3-brand-text span:last-child {
  font-weight: 800;
  font-style: italic;
}

.f3-menu-icon {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8px;
  cursor: pointer;
}

.f3-menu-icon div:first-child {
  width: 45px;
  height: 4px;
  background: #000;
}

.f3-menu-icon div:last-child {
  width: 35px;
  height: 4px;
  background: #000;
}

.f3-content-grid {
  display: grid;
  grid-template-columns: 1fr 450px 1fr;
  flex: 1;
  position: relative;
  z-index: 10;
}

.f3-left-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-right: 2rem;
}

.f3-title {
  display: flex;
  flex-direction: column;
  line-height: 1.15;
  margin-bottom: 1.5rem;
}

.f3-title-word {
  font-weight: 900;
  font-style: italic;
  font-size: 4.5rem;
  color: #000;
  letter-spacing: 0.02em;
}

.f3-title-word.shadowed {
  text-shadow: 4px 8px 15px rgba(0,0,0,0.25);
  margin-left: -5px;
}

.f3-title-word.indented {
  margin-left: 80px;
}

.f3-desc {
  font-weight: 600;
  font-style: italic;
  font-size: 0.9rem;
  color: #444;
  line-height: 1.8;
  max-width: 310px;
  margin-bottom: 2rem;
}

.f3-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 0.5rem;
  max-width: 380px;
  margin-bottom: 2rem;
}

.f3-tag {
  background: #efefef;
  color: #333;
  padding: 0.5rem 1.2rem;
  border-radius: 99px;
  font-size: 0.8rem;
  font-weight: 600;
  font-style: italic;
  white-space: nowrap;
}

.f3-price-area {
  display: flex;
  align-items: flex-end;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.f3-price-main {
  font-size: 3.5rem;
  font-weight: 900;
  line-height: 0.85;
  letter-spacing: -0.03em;
  color: #000;
}

.f3-price-strike {
  font-size: 1.2rem;
  font-weight: 600;
  text-decoration: line-through;
  color: #999;
  margin-bottom: 4px;
}

.f3-discount-badge {
  background: #dcdcdc;
  color: #000;
  font-size: 0.65rem;
  font-weight: 800;
  padding: 3px 6px;
  border-radius: 4px;
  margin-bottom: 6px;
}

.f3-add-btn {
  background: #fdf5d3;
  color: #000;
  font-size: 1.2rem;
  font-weight: 800;
  font-style: italic;
  padding: 1.1rem 2.5rem;
  border: none;
  border-radius: 99px;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  width: max-content;
  cursor: pointer;
  transition: background 0.2s;
}

.f3-add-btn:hover {
  background: #f5eaaf;
}

.f3-center-col {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.f3-glow-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 26vw;
  font-weight: 900;
  color: #f1f1f1;
  letter-spacing: -0.04em;
  z-index: 0;
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
}

.f3-product-img {
  position: relative;
  z-index: 10;
  max-width: 110%;
  height: auto;
  max-height: 80vh;
  object-fit: contain;
  filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));
}

.f3-right-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 2rem;
}

.f3-specs-list {
  display: flex;
  flex-direction: column;
}

.f3-spec-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 1rem 0;
  border-bottom: 2px solid #e8e8e8;
  gap: 1.5rem;
}

.f3-spec-label {
  font-size: 1.3rem;
  font-weight: 700;
  font-style: italic;
  color: #b3b3b3;
  line-height: 1;
}

.f3-spec-values {
  text-align: right;
  line-height: 1.3;
}

.f3-spec-val-main {
  font-size: 0.85rem;
  font-weight: 800;
  font-style: italic;
  color: #111;
}

.f3-spec-val-sub {
  font-size: 0.75rem;
  font-weight: 600;
  font-style: italic;
  color: #777;
}

.f3-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-top: 2px solid #e8e8e8;
  padding-top: 1rem;
  margin-top: 2rem;
  position: relative;
  z-index: 10;
}

.f3-footer-left {
  font-weight: 900;
  font-style: italic;
  font-size: 1.15rem;
  color: #a4a4a4;
  letter-spacing: 0.05em;
}

.f3-footer-center {
  font-size: 0.78rem;
  font-weight: 800;
  color: #9f9f9f;
  letter-spacing: 0.02em;
}

.f3-footer-right {
  font-size: 0.7rem;
  font-weight: 800;
  color: #666;
}

@media(max-width: 1200px) {
  .f3-content-grid { grid-template-columns: 1fr 1fr; }
  .f3-right-col { grid-column: 1 / -1; padding-left: 0; margin-top: 3rem; }
  .f3-center-col { order: -1; grid-column: 1 / -1; }
  .f3-left-col { grid-column: 1 / -1; padding-right: 0; }
  .f3-card { padding: 2rem; border-radius: 24px; }
}
{% endstyle %}

<section class="f3-wrapper" id="Hero">
