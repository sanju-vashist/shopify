              <div class="f3-spec-val-main">Borosilicate Glass</div>
              <div class="f3-spec-val-sub">Heavy-wall, heat-resistant</div>
            </div>
          </div>
          <div class="f3-spec-item">
            <span class="f3-spec-label">Free From</span>
