<div class="founder-section">
  <div class="founder-container">
    <div class="founder-image-col">
      <div class="founder-bg-text">FOUNDER</div>
      <div class="founder-img-wrap">
        <img src="{{ 'founder.jpg' | asset_url }}" alt="Malvika Jain, Founder & CEO" onerror="this.src='https://via.placeholder.com/600x800/d6d6eb/000000?text=Malvika+Jain';">
      </div>
    </div>
    <div class="founder-text-col">
      <p class="founder-quote">
        "When my cousin's skin dramatically improved as a result of her mental health treatment - a lightbulb went on. Clearly, the skincare industry overlooked a fundamental truth: the <strong>SKIN-MIND</strong> connection."
      </p>
      <div class="founder-signature">Malvika Jain</div>
      <div class="founder-title">FOUNDER & CEO</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Founder Section",
  "settings": [],
  "presets": [
    {
      "name": "Founder Section"
    }
  ]
}
{% endschema %}
