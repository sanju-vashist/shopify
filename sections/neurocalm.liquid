<div class="neurocalm-section">
  <div class="neurocalm-grid">
    <div class="neurocalm-main" data-animate>
      <h2 class="neurocalm-title">
        How does NeuroCalm®
        <span>help the Skin?</span>
      </h2>
      <div class="neurocalm-diagram">
        <img src="{{ 'neurocalm-diagram.png' | asset_url }}" alt="NeuroCalm mechanism on skin" width="800" height="600" onerror="this.src='https://via.placeholder.com/800x600/fcf1f0/000000?text=NeuroCalm+Mechanism';">
      </div>
    </div>
    
    <div class="neurocalm-side">
      <div class="neurocalm-side-top-row">
        <div class="neurocalm-side-card pen-card" data-animate>
          <img src="{{ 'calming-pen.png' | asset_url }}" alt="Calming Dew Pen" width="200" height="250" onerror="this.src='https://via.placeholder.com/200x250/e0e0f0/000000?text=Pen';">
        </div>
        <div class="neurocalm-side-card cortisol-card" data-animate>
          <img src="{{ 'reduction-cortisol.png' | asset_url }}" alt="70% Reduction in Cortisol" width="200" height="250" onerror="this.src='https://via.placeholder.com/200x250/b8bacf/ffffff?text=Face';">
          <div class="neurocalm-side-overlay">
            <div class="neurocalm-side-text">70% REDUCTION<br>IN CORTISOL</div>
          </div>
        </div>
      </div>
      
      <div class="neurocalm-side-card icons-card" data-animate>
        <img src="{{ 'neurocalm-icons.png' | asset_url }}" alt="NeuroCalm Properties" width="400" height="200" onerror="this.src='https://via.placeholder.com/400x200/fdfaf6/000000?text=NeuroCalm+Icons';">
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "NeuroCalm Section",
  "settings": [],
  "presets": [
    {
      "name": "NeuroCalm Section"
    }
  ]
}
{% endschema %}
