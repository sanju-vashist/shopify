{% if section.settings.show_announcement %}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__inner">
    {% if section.settings.announcement_link != blank %}
      <a href="{{ section.settings.announcement_link }}" class="announcement-bar__text">{{ section.settings.announcement_text }}</a>
    {% else %}
      <p class="announcement-bar__text">{{ section.settings.announcement_text }}</p>
    {% endif %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "✦ Free shipping on orders above ₹799 ✦ Dermatologist Tested ✦ Cruelty-Free" },
    { "type": "url", "id": "announcement_link", "label": "Link (optional)" }
  ]
}
{% endschema %}
