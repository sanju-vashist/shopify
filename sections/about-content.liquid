<div class="about-page section">
  <div class="container">
    <!-- Hero -->
    <div class="about-hero">
      <p class="section-eyebrow">{{ section.settings.eyebrow | default: 'Our Story' }}</p>
      <h1 class="about-hero__title">{{ section.settings.title | default: 'Beauty. Wellness. Confidence.' }}</h1>
      <p class="about-hero__sub">{{ section.settings.subtitle | default: 'A modern beauty brand built for real women.' }}</p>
      {%- if section.settings.hero_image != blank -%}
        <div class="about-hero__image">
          <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image.alt }}" loading="lazy">
        </div>
      {%- endif -%}
    </div>

    <!-- Mission / Vision / Values -->
    <div class="about-pillars">
      <div class="about-pillar">
        <div class="about-pillar__icon">◆</div>
        <h3>Who We Are</h3>
        <p>Omnilyx is a modern beauty and women's hygiene brand dedicated to empowering women through safe, innovative, and reliable personal care products.</p>
      </div>
      <div class="about-pillar">
        <div class="about-pillar__icon">◆</div>
        <h3>Our Vision</h3>
        <p>To become a leading global brand offering innovative, eco-friendly, and customer-focused beauty and hygiene solutions.</p>
      </div>
      <div class="about-pillar">
        <div class="about-pillar__icon">◆</div>
        <h3>Our Mission</h3>
        <p>Deliver premium cosmetic and hygiene products that promote wellness, confidence, and healthy lifestyles for every woman.</p>
      </div>
    </div>

    <!-- Values -->
    <div class="about-values">
      <h2 class="about-values__title">Our Core Values</h2>
      <div class="about-values__grid">
        {%- assign values = "Quality & Safety,Customer Trust,Innovation,Sustainability,Ethical Practices,Transparency" | split: "," -%}
        {%- for val in values -%}
          <div class="about-value-chip">{{ val }}</div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Page Content -->
    {%- if page.content != blank -%}
      <div class="about-page__content rte">{{ page.content }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About Content",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "title", "label": "Title", "default": "Beauty. Wellness. Confidence." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "A modern beauty brand built for real women." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" }
  ]
}
{% endschema %}
