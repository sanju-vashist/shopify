<header class="site-header" id="SiteHeader" role="banner">
  <div class="container">
    <div class="header__inner">

      <!-- Menu Toggle -->
      <button class="header__menu-btn btn-icon" id="NavToggle" aria-label="Open menu" aria-expanded="false" aria-controls="NavDrawer">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none">
          <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="0" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Logo -->
      <div class="header__logo">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 180 }}" alt="{{ shop.name }}" width="180" height="auto">
          {%- else -%}
            <span class="header__logo-text">{{ shop.name | upcase }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="header__nav" aria-label="Main navigation">
        {% for link in linklists[section.settings.menu].links %}
          <a href="{{ link.url }}"
             class="header__nav-link{% if link.active %} active{% endif %}"
             {% if link.current %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {% endfor %}
      </nav>

      <!-- Header Actions -->
      <div class="header__actions">
        <!-- Search -->
        <button class="btn-icon" id="SearchToggle" aria-label="Search" aria-expanded="false">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        <!-- Account -->
        <a href="{{ routes.account_url }}" class="btn-icon" aria-label="Account">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        <!-- Cart -->
        <button class="btn-icon header__cart-btn" id="CartToggle" aria-label="Open cart" aria-expanded="false">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="header__cart-count{% if cart.item_count == 0 %} hidden{% endif %}" id="HeaderCartCount">
            {{ cart.item_count }}
          </span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Nav Drawer -->
<div class="nav-drawer" id="NavDrawer" aria-hidden="true" role="dialog" aria-label="Navigation">
  <div class="nav-drawer__overlay" id="NavOverlay"></div>
  <div class="nav-drawer__panel">
    <div class="nav-drawer__head">
      <span class="nav-drawer__logo">{{ shop.name | upcase }}</span>
      <button class="btn-icon" id="NavClose" aria-label="Close menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <nav class="nav-drawer__nav">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" class="nav-drawer__link">{{ link.title }}</a>
      {% endfor %}
    </nav>
    <div class="nav-drawer__foot">
      <a href="{{ routes.account_url }}" class="nav-drawer__link">My Account</a>
      <a href="{{ routes.cart_url }}" class="nav-drawer__link">My Bag ({{ cart.item_count }})</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 300, "step": 10, "default": 160, "unit": "px", "label": "Logo width" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" },
    { "type": "checkbox", "id": "enable_sticky", "label": "Sticky header", "default": true }
  ]
}
{% endschema %}
