      { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "✦ Free shipping on orders above ₹799 ✦ Dermatologist Tested ✦ Cruelty-Free" },
      { "type": "url", "id": "announcement_link", "label": "Announcement link" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "playfair_display_n7" },
      { "type": "font_picker", "id": "body_font", "label": "Body font", "default": "poppins_n4" }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg", "label": "Background", "default": "#ffffff" },
      { "type": "color", "id": "color_text", "label": "Primary text", "default": "#1a1a1a" },
      { "type": "color", "id": "color_accent", "label": "Accent (Gold)", "default": "#c9a84c" },
      { "type": "color", "id": "color_border", "label": "Border color", "default": "#e8e4df" }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_twitter", "label": "Twitter / X URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" }
