  },
  {
    "name": "Cart",
    "settings": [
      { "type": "checkbox", "id": "enable_cart_drawer", "label": "Enable cart drawer", "default": true },
      { "type": "checkbox", "id": "show_cart_note", "label": "Enable order notes", "default": true }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      { "type": "image_picker", "id": "favicon", "label": "Favicon image" }
